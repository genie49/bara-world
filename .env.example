# Bara World 로컬 개발용 환경변수.
# 이 파일을 `.env`로 복사 후 값을 채운다. `.env`는 gitignored.
#
# apps/auth/build.gradle.kts의 bootRun task가 이 파일을 읽어 환경변수로 주입한다.
# 상세 가이드: docs/guides/auth-local-setup.md

# ─── JWT RSA 키쌍 ────────────────────────────────────────────────────
# RS256 서명용. base64(PEM) 형식으로 저장한다.
#
# 생성 (1회):
#   openssl genrsa -out /tmp/jwt-priv.pem 2048
#   openssl rsa -in /tmp/jwt-priv.pem -pubout -out /tmp/jwt-pub.pem
#   echo "BARA_AUTH_JWT_PRIVATE_KEY=$(base64 < /tmp/jwt-priv.pem | tr -d '\n')"
#   echo "BARA_AUTH_JWT_PUBLIC_KEY=$(base64 < /tmp/jwt-pub.pem | tr -d '\n')"
#   rm /tmp/jwt-priv.pem /tmp/jwt-pub.pem
BARA_AUTH_JWT_PRIVATE_KEY=
BARA_AUTH_JWT_PUBLIC_KEY=

# ─── Google OAuth 2.0 Client ─────────────────────────────────────────
# Google Cloud Console에서 OAuth 2.0 Client ID (Web application) 생성.
# Authorized redirect URIs에 아래 BARA_AUTH_GOOGLE_REDIRECT_URI 값을 등록한다.
#   https://console.cloud.google.com/apis/credentials
BARA_AUTH_GOOGLE_CLIENT_ID=
BARA_AUTH_GOOGLE_CLIENT_SECRET=
BARA_AUTH_GOOGLE_REDIRECT_URI=http://localhost/auth/google/callback
